<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.miqdad71.starworks">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher_starworks"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_starworks_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.StarworkS"
        android:usesCleartextTraffic="true">
        <activity android:name=".view.activities.main.company.AddProjectActivity"></activity>
        <activity android:name=".view.activities.main.company.HireCompanyActivity" />
        <activity android:name=".project.ListEngineerActivity" />
        <activity android:name=".view.webview.WebViewActivity" />
        <activity android:name=".view.adapter.EngineerLayoutActivity" />
        <activity android:name=".view.dialog.DialogActivity" />
        <activity android:name=".view.activities.main.engineer.EngineerMainActivity" />
        <activity android:name=".view.activities.main.company.CompanyMainActivity" />
        <activity android:name=".view.activities.signup.SignUpActivity" />
        <activity android:name=".view.activities.forgetpassword.ForgetPasswordVerifyActivity" />
        <activity android:name=".view.activities.forgetpassword.ForgetPasswordActivity" />
        <activity android:name=".view.activities.OnboardActivity" />
        <activity android:name=".view.activities.experience.ExperienceActivity" />
        <activity android:name=".view.activities.login.LoginActivity" />
        <activity android:name=".view.activities.splash.SplashScreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>